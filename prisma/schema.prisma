generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Users {
  id        String     @id @default(uuid())
  email     String     @unique
  firstname String
  lastname  String
  password  String
  username  String?    @unique
  phone     String?
  location  String?
  image     String?
  bio       String?
  status    UserStatus
  joinedAt  DateTime   @default(now())
  roleId    String
  role      Role       @relation(fields: [roleId], references: [id])
  vendors   Vendors?
  bookings  Bookings[]
}

model Vendors {
  id                  String        @id @default(uuid())
  name                String
  locations           Location[]
  services            Service[]
  description         String?
  image               String?
  phone               String?
  photos              String?
  cancellation_policy String?
  categoryId          String
  category            Category      @relation(fields: [categoryId], references: [id])
  planId              String
  plan                Plans         @relation(fields: [planId], references: [id])
  status              AccountStatus @default(ACTIVE)
  joinedAt            DateTime      @default(now())
  trialEndsAt         DateTime?
  userId              String        @unique
  user                Users         @relation(fields: [userId], references: [id])
  isComplete          Boolean       @default(false)
  professionals       Professional[]
}

model Category {
  id      String    @id @default(uuid())
  name    String    @unique
  image   String?
  vendors Vendors[]
}

model Plans {
  id          String    @id @default(uuid())
  name        String @unique
  price       Float
  duration    Int
  trial_period Int
  billing_cycle String
  createdAt  DateTime @default(now())
  professional   Int        @default(1)
  vendors     Vendors[]
  location Int @default(1)
}

model Role {
  id    String  @id @default(cuid())
  name  String  @unique
  users Users[]
}

model Bookings {
  id        String        @id @default(cuid())
  date      DateTime
  createdAt DateTime      @default(now())
  status    BookingStatus @default(PENDING)
  scheduledAt DateTime
  userId    String
  user      Users         @relation(fields: [userId], references: [id])
  serviceId  String
  service    Service       @relation(fields: [serviceId], references: [id])
}

model Invitation {
  id        String   @id @default(uuid())
  email     String   @unique
  token     String
  expiresAt DateTime
  used      Boolean  @default(false)
}
model Location {
  id              String      @id @default(cuid())
  vendorId        String
  vendor          Vendors     @relation(fields: [vendorId], references: [id])

  // --- Physical Address for business locations ---
  address         String?     // optional if service is only at client
  latitude        Float?      // for map display / distance calculation
  longitude       Float?

  // --- Service type flags ---
  offerAtClient   Boolean     @default(false) // Business Provider travels to client
  offerAtBusiness Boolean     @default(false) // client visits business

  // --- Service Areas (only needed for client-based service) ---
  businessAreas   BusinessArea[] // links to City table for serviceable areas

  // --- Optional metadata ---
  phone           String?     
  openHours       String?     
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model City {
  id        String          @id @default(cuid())
  name      String
  state     String?
  country   String?
  latitude  Float?
  longitude Float?
  locations BusinessArea[]
}

model BusinessArea {
  id         String   @id @default(cuid())
  locationId String
  cityId     String
  location   Location @relation(fields: [locationId], references: [id])
  city       City     @relation(fields: [cityId], references: [id])
  @@unique([locationId, cityId])
}

model Service{
  id        String @id @default(cuid())
  name      String 
  description String?
  vendorId  String
  vendor    Vendors @relation(fields: [vendorId],references: [id])
  price     Float
  duration      Int
  booking   Bookings[]
  @@unique([name, vendorId])
}


model Professional {
  id         String   @id @default(uuid())
  name       String
  email      String?  @unique
  phone      String?
  vendorId   String
  vendor     Vendors  @relation(fields: [vendorId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  roleId   String
  role     ProfessionalRole @relation(fields: [roleId], references: [id])
  status    ProfessionalStatus @default(INACTIVE)
}

model ProfessionalRole {
  id    String @id @default(cuid())
  name  String @unique
  professionals Professional[]
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELED
  COMPLETED
}

enum AccountStatus {
  TRIAL_ACTIVE
  TRIAL_EXPIRING
  TRIAL_EXPIRED
  ACTIVE
  INACTIVE
  PENDING
}

enum ProfessionalStatus {
  ACTIVE
  INACTIVE
  PENDING
}

